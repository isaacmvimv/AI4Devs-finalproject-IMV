{
  "name": "ConRutina",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "vite",
    "dev:api": "tsx watch backend/src/main.ts",
    "api": "tsx watch backend/src/main.ts",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint frontend/src backend/src",
    "format": "prettier --write \"frontend/src/**/*.{ts,tsx,css}\" \"backend/src/**/*.ts\" \"*.{json,md,mjs}\"",
    "format:check": "prettier --check \"frontend/src/**/*.{ts,tsx,css}\" \"backend/src/**/*.ts\" \"*.{json,md,mjs}\"",
    "typecheck": "tsc --noEmit -p frontend/tsconfig.json && tsc --noEmit -p backend/tsconfig.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose stop db",
    "docker:up": "docker compose up -d db",
    "docker:down": "docker compose stop db",
    "docker:logs": "docker compose logs -f db",
    "prisma:init": "npx prisma init",
    "prisma:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate deploy",
    "db:seed": "npx prisma db seed",
    "openspec:mark-ticket": "node scripts/openspec-mark-ticket-implemented.mjs",
    "openspec:extract-ticket": "node scripts/openspec-extract-ticket.mjs"
  },
  "prisma": {
    "schema": "backend/prisma/schema.prisma",
    "seed": "tsx backend/prisma/seed.ts"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.5",
    "@mui/material": "7.3.5",
    "@popperjs/core": "2.11.8",
    "@prisma/client": "^5.13.0",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-dialog": "1.1.6",
    "canvas-confetti": "1.9.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cors": "^2.8.6",
    "date-fns": "3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next-themes": "0.4.6",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-hook-form": "7.55.0",
    "react-popper": "2.3.0",
    "react-responsive-masonry": "2.7.1",
    "react-router": "7.13.0",
    "react-slick": "0.31.0",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "4.1.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prisma": "^5.13.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "supertest": "^7.2.2",
    "tailwindcss": "4.1.12",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "6.4.2",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  }
}
